APP_NAME="Shared Living Room Reservations"
APP_ENV=local
APP_DEBUG=true
APP_INSTALLED=false
APP_URL=http://localhost:8080
APP_TIMEZONE=Europe/Amsterdam
APP_LOCALE=en
SESSION_NAME=livingroom_session
SESSION_SECURE=false
APP_VERSION=0.2.0

DB_HOST=db
DB_PORT=3306
DB_DATABASE=living_room
DB_USERNAME=living_room
DB_PASSWORD=change_me_database_password
DB_CHARSET=utf8mb4
DB_ROOT_PASSWORD=change_me_root_password

ADMIN_EMAIL=admin@example.com
PAGINATION_SIZE=10

MAILJET_ENABLED=false
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME="Living Room App"

TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

UPDATE_ENABLED=false
UPDATE_REPOSITORY_URL=https://github.com/finnwastakenwastaken/magnus-reservation-system.git
UPDATE_REPOSITORY_BRANCH=main
UPDATE_STRATEGY=auto
UPDATE_GIT_BIN=git
UPDATE_CHECK_AUTOMATIC=false
UPDATE_BACKUP_PATH=storage/backups
UPDATE_TEMP_PATH=storage/updates
